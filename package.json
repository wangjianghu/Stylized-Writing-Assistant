    "viewsWelcome": [
      {
        "view": "quickActions",
        "contents": "常用入口：\n[导入样本数据](command:writingAgent.importArticle)\n[根据主题写作](command:writingAgent.generateArticle)\n[搜索素材](command:writingAgent.searchMaterial)"
      },
      {
        "view": "materialLibrary",
        "contents": "素材按当前风格隔离。\n请先创建或切换风格，再导入与搜索。\n[新建风格](command:writingAgent.createStyle)\n[切换风格](command:writingAgent.switchStyle)\n[导入样本数据](command:writingAgent.importArticle)\n[搜索素材](command:writingAgent.searchMaterial)"
      },
      {
        "view": "styleProfile",
        "contents": "尚未配置风格。\n[新建风格](command:writingAgent.createStyle)\n[导入样本数据](command:writingAgent.importArticle)\n[刷新风格配置](command:writingAgent.refreshStyleProfile)"
      },
      {
        "view": "quickActionsExplorer",
        "contents": "常用入口（Explorer 兜底）：\n[导入样本数据](command:writingAgent.importArticle)\n[根据主题写作](command:writingAgent.generateArticle)\n[搜索素材](command:writingAgent.searchMaterial)"
      },
      {
        "view": "materialLibraryExplorer",
        "contents": "素材按当前风格隔离（Explorer 兜底入口）。\n请先创建或切换风格，再导入与搜索。\n[新建风格](command:writingAgent.createStyle)\n[切换风格](command:writingAgent.switchStyle)\n[导入样本数据](command:writingAgent.importArticle)\n[搜索素材](command:writingAgent.searchMaterial)"
      },
      {
        "view": "styleProfileExplorer",
        "contents": "尚未配置风格（Explorer 兜底入口）。\n[新建风格](command:writingAgent.createStyle)\n[导入样本数据](command:writingAgent.importArticle)\n[刷新风格配置](command:writingAgent.refreshStyleProfile)"
      },
      {
        "view": "articleCollection",
        "contents": "文集用于管理已生成文稿。\\n[根据主题写作](command:writingAgent.generateArticle)\\n[打开文集](command:writingAgent.showArticleCollection)\\n[分析当前文档风格](command:writingAgent.analyzeStyle)\\n[使用 IDE AI 续写当前文稿](command:writingAgent.useHostAI)\\n[配置 API](command:writingAgent.configureApi)\\n[从剪贴板写入当前文稿](command:writingAgent.applyClipboardToDraft)"
      },
      {
        "view": "articleCollectionExplorer",
        "contents": "文集（Explorer 兜底入口）。\\n[根据主题写作](command:writingAgent.generateArticle)\\n[打开文集](command:writingAgent.showArticleCollection)\\n[分析当前文档风格](command:writingAgent.analyzeStyle)\\n[使用 IDE AI 续写当前文稿](command:writingAgent.useHostAI)\\n[配置 API](command:writingAgent.configureApi)\\n[从剪贴板写入当前文稿](command:writingAgent.applyClipboardToDraft)"
      }
    ],
    "keybindings": [
      {
        "command": "writingAgent.generateArticle",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "writingAgent.importArticle",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      },
      {
        "command": "writingAgent.analyzeStyle",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "writingAgent.saveMaterial",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "writingAgent.searchMaterial",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      }
    ],
