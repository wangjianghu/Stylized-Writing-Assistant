            "OpenRouter",
            "Kimi",
            "DeepSeek",
            "MiniMax",
            "千问",
            "自定义 OpenAI 兼容"
          ],
          "description": "当前启用的 API 提供商"
        },
        "writingAgent.api.providerOrder": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "API 提供商调用顺序（按数组顺序依次尝试）"
        },
        "writingAgent.api.baseUrl": {
          "type": "string",
          "default": "https://apis.iflow.cn/v1",
          "description": "统一 API Base URL（OpenAI 兼容）"
        },
        "writingAgent.api.model": {
          "type": "string",
          "default": "Qwen/Qwen3-8B",
          "description": "统一 API 模型名称"
        },
        "writingAgent.api.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "统一 API 模型列表（按优先级顺序轮换，首项优先）"
        },
        "writingAgent.api.providerConfigs": {
          "type": "object",
          "default": {},
          "description": "各 API 提供商的独立模型与地址配置缓存（由命令自动维护）"
        },
        "writingAgent.api.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "统一 API 生成温度"
        },
        "writingAgent.api.maxTokens": {
          "type": "number",
          "default": 10000,
          "minimum": 200,
