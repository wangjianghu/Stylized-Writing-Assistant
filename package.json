    "configuration": {
      "title": "写作助手",
      "properties": {
        "writingAgent.autoExtract": {
          "type": "boolean",
          "default": true,
          "description": "自动提取素材"
        },
        "writingAgent.suggestionDelay": {
          "type": "number",
          "default": 500,
          "description": "建议延迟时间（毫秒）"
        },
        "writingAgent.suggestionMinChars": {
          "type": "number",
          "default": 6,
          "minimum": 2,
          "maximum": 20,
          "description": "自动补全最小触发字符数"
        },
        "writingAgent.storage.path": {
          "type": "string",
          "default": "",
          "scope": "application",
          "description": "插件内容存储根目录（文集、素材库、样本学习数据）。留空优先使用 ~/Downloads/writing-angent；若无权限会自动回退到扩展全局存储目录"
        },
        "writingAgent.ai.channel": {
          "type": "string",
          "default": "api",
          "enum": [
            "api",
            "ide-chat"
          ],
          "enumDescriptions": [
            "默认：使用统一 API 直接生成结果",
            "可选：使用 IDE AI 对话，并自动填充提示词到 Chat 输入框（宿主支持时）"
          ],
          "description": "根据主题写作、续写、选区改写的 AI 通道"
        },
        "writingAgent.iflow.enabled": {
          "type": "boolean",
          "default": true,
          "description": "是否启用心流 API 作为文章生成主通道",
          "markdownDeprecationMessage": "已兼容读取，建议迁移到 `writingAgent.api.*`。"
        },
        "writingAgent.iflow.baseUrl": {
          "type": "string",
          "default": "https://apis.iflow.cn/v1",
          "description": "心流 API Base URL（OpenAI 兼容）",
          "markdownDeprecationMessage": "已兼容读取，建议迁移到 `writingAgent.api.*`。"
        },
        "writingAgent.iflow.model": {
          "type": "string",
          "default": "Qwen/Qwen3-8B",
          "description": "心流 API 模型名称",
          "markdownDeprecationMessage": "已兼容读取，建议迁移到 `writingAgent.api.*`。"
        },
        "writingAgent.iflow.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "兼容旧字段。建议使用命令“写作助手: 配置 API”并迁移到 `writingAgent.api.*`；也可设置环境变量 `IFLOW_API_KEY`。",
          "markdownDeprecationMessage": "已兼容读取，建议迁移到 `writingAgent.api.*`。"
        },
        "writingAgent.iflow.temperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 2,
          "description": "心流 API 生成温度",
          "markdownDeprecationMessage": "已兼容读取，建议迁移到 `writingAgent.api.*`。"
        },
        "writingAgent.iflow.maxTokens": {
          "type": "number",
          "default": 10000,
          "minimum": 200,
          "description": "心流 API 最大输出 token 数",
          "markdownDeprecationMessage": "已兼容读取，建议迁移到 `writingAgent.api.*`。"
        },
        "writingAgent.iflow.timeoutMs": {
          "type": "number",
          "default": 60000,
          "minimum": 5000,
          "description": "心流 API 请求超时（毫秒）",
          "markdownDeprecationMessage": "已兼容读取，建议迁移到 `writingAgent.api.*`。"
        },
        "writingAgent.api.enabled": {
          "type": "boolean",
          "default": true,
