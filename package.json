{
  "name": "writing-agent",
  "displayName": "风格化写作助手",
  "description": "智能写作助手，自动学习风格，生成风格一致的文章",
  "version": "0.0.3",
  "publisher": "daydayup2026",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "keywords": [
    "writing",
    "style",
    "material",
    "assistant",
    "AI"
  ],
  "activationEvents": [
    "onCommand:writingAgent.generateArticle",
    "onCommand:writingAgent.saveMaterial",
    "onCommand:writingAgent.analyzeStyle",
    "onCommand:writingAgent.searchMaterial",
    "onCommand:writingAgent.importArticle",
    "onCommand:writingAgent.exportMaterials",
    "onCommand:writingAgent.refreshMaterialLibrary",
    "onCommand:writingAgent.refreshStyleProfile",
    "onCommand:writingAgent.createStyle",
    "onCommand:writingAgent.switchStyle",
    "onCommand:writingAgent.renameStyle",
    "onCommand:writingAgent.deleteStyle",
    "onCommand:writingAgent.showAssistantViews",
    "onCommand:writingAgent.openMaterialLibrary",
    "onCommand:writingAgent.openStyleProfile",
    "onView:quickActions",
    "onView:materialLibrary",
    "onView:styleProfile",
    "onView:quickActionsExplorer",
    "onView:materialLibraryExplorer",
    "onView:styleProfileExplorer",
    "onCommand:writingAgent.refreshArticleCollection",
    "onCommand:writingAgent.showArticleCollection",
    "onCommand:writingAgent.useHostAI",
    "onCommand:writingAgent.configureIFlowApi",
    "onCommand:writingAgent.rewriteSelectionWithIFlow",
    "onView:articleCollection",
    "onView:articleCollectionExplorer",
    "onCommand:writingAgent.applyClipboardToDraft",
    "onCommand:writingAgent.configureApi",
    "onCommand:writingAgent.reorderApiProviders",
    "onCommand:writingAgent.reorderApiModels",
    "onCommand:writingAgent.configureSuggestionMinChars",
    "onCommand:writingAgent.deleteArticle",
    "onCommand:writingAgent.testApiConnection"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "writingAgent.generateArticle",
        "title": "写作助手: 生成风格化文章",
        "shortTitle": "生成"
      },
      {
        "command": "writingAgent.saveMaterial",
        "title": "写作助手: 保存素材"
      },
      {
        "command": "writingAgent.analyzeStyle",
        "title": "写作助手: 分析风格",
        "shortTitle": "分析风格"
      },
      {
        "command": "writingAgent.searchMaterial",
        "title": "写作助手: 搜索素材",
        "shortTitle": "搜索"
      },
      {
        "command": "writingAgent.importArticle",
        "title": "写作助手: 导入样本数据",
        "shortTitle": "导入"
      },
      {
        "command": "writingAgent.exportMaterials",
        "title": "写作助手: 导出素材",
        "shortTitle": "导出"
      },
      {
        "command": "writingAgent.refreshMaterialLibrary",
        "title": "写作助手: 刷新素材库",
        "shortTitle": "刷新"
      },
      {
        "command": "writingAgent.refreshStyleProfile",
        "title": "写作助手: 刷新风格配置",
        "shortTitle": "刷新"
      },
      {
        "command": "writingAgent.createStyle",
        "title": "写作助手: 新建风格",
        "shortTitle": "新建"
      },
      {
        "command": "writingAgent.switchStyle",
        "title": "写作助手: 切换风格",
        "shortTitle": "切换风格"
      },
      {
        "command": "writingAgent.renameStyle",
        "title": "写作助手: 重命名风格",
        "shortTitle": "重命名"
      },
      {
        "command": "writingAgent.deleteStyle",
        "title": "写作助手: 删除风格",
        "shortTitle": "删除风格"
      },
      {
        "command": "writingAgent.showAssistantViews",
        "title": "写作助手: 显示写作助手"
      },
      {
        "command": "writingAgent.openMaterialLibrary",
        "title": "写作助手: 打开素材库"
      },
      {
        "command": "writingAgent.openStyleProfile",
        "title": "写作助手: 打开风格配置"
      },
      {
        "command": "writingAgent.refreshArticleCollection",
        "title": "写作助手: 刷新文集",
        "shortTitle": "刷新"
      },
      {
        "command": "writingAgent.showArticleCollection",
        "title": "写作助手: 打开文集"
      },
      {
        "command": "writingAgent.useHostAI",
        "title": "写作助手: 使用 IDE AI 续写当前文稿",
        "shortTitle": "续写"
      },
      {
        "command": "writingAgent.configureIFlowApi",
        "title": "写作助手: 配置 API（兼容）"
      },
      {
        "command": "writingAgent.rewriteSelectionWithIFlow",
        "title": "写作助手: AI编辑选中文本",
        "shortTitle": "改写"
      },
      {
        "command": "writingAgent.applyClipboardToDraft",
        "title": "写作助手: 从剪贴板写入当前文稿",
        "shortTitle": "写入结果"
      },
      {
        "command": "writingAgent.configureApi",
        "title": "写作助手: 配置 API",
        "shortTitle": "配置 API"
      },
      {
        "command": "writingAgent.reorderApiProviders",
        "title": "写作助手: 拖拽调整 API 提供商顺序",
        "shortTitle": "提供商顺序"
      },
      {
        "command": "writingAgent.reorderApiModels",
        "title": "写作助手: 拖拽调整 API 模型顺序",
        "shortTitle": "模型顺序"
      },
      {
        "command": "writingAgent.configureSuggestionMinChars",
        "title": "写作助手: 设置自动补全最小触发字符数",
        "shortTitle": "补全触发字数"
      },
      {
        "command": "writingAgent.deleteArticle",
        "title": "删除文章"
      },
      {
        "command": "writingAgent.testApiConnection",
        "title": "写作助手: 测试 API 配置",
        "shortTitle": "测试 API"
      }
    ],
